{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "stat",
      "title": "Rows Scored (last run)",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "batch_rows_scored", "refId": "A", "datasource": "${DS_PROMETHEUS}", "instant": true }
      ]
    },
    {
      "type": "stat",
      "title": "Champion Model Version",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "batch_model_version", "refId": "A", "datasource": "${DS_PROMETHEUS}", "instant": true }
      ]
    },
    {
      "type": "stat",
      "title": "Time Since Last Batch Run",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 691200 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        { "expr": "time() - batch_last_success_timestamp", "refId": "A", "datasource": "${DS_PROMETHEUS}", "instant": true }
      ]
    },
    {
      "type": "table",
      "title": "Anomaly Count by Tier / Class",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true },
      "targets": [
        {
          "expr": "batch_anomaly_count",
          "refId": "A",
          "datasource": "${DS_PROMETHEUS}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true },
            "renameByName": { "tier": "Tier", "predicted_class": "Class", "Value": "Count" }
          }
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["tsd", "batch"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "TSD Batch Scoring",
  "version": 1
}
